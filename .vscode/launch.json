{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MarketAssAgent REPL",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/cli/run.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "MarketAssAgent 单轮",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/cli/run.py",
      "args": ["BTC_USDT 行情分析"],
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "行情分析 CLI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/cli/stock_analysis.py",
      "args": ["--provider", "gateio", "--symbol", "BTC_USDT"],
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "飞书 Bot",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/cli/feishu_bot.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}