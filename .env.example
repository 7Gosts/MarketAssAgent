# FastAPI
HOST=0.0.0.0
PORT=8000

# Feishu
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token

# LLM（可切换）
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# 可选：指定模型
LLM_MODEL=gpt-4o-mini

# Database
DATABASE_URL=sqlite:///./market_agent.db
