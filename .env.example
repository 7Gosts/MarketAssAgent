# ── LLM 配置（推荐使用环境变量覆盖 analysis_defaults.yaml）──
# 支持 OpenAI / DeepSeek / OpenRouter 等 OpenAI-compatible 提供商

# 默认使用 OpenAI
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-4o-mini

# 切换到 DeepSeek（需在 analysis_defaults.yaml 中配置或通过环境变量）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# LLM_PROVIDER=deepseek

# 其他可选提供商
# OPENROUTER_API_KEY=sk-...
# HCT_API_KEY=sk-...

# ── 数据库配置 ──
DATABASE_URL=postgresql+psycopg://stock_user:111@127.0.0.1:5432/stock_analysis

# ── 数据源配置 ──

# tickflow（A 股 / 美股 / 港股）— 有 key 用付费端点，无 key 自动走免费端点
# TICKFLOW_API_KEY=your_tickflow_key

# goldapi（黄金 / 贵金属）— 默认使用内置 key，也可覆盖
# GOLD_API_BASE=https://gold-api.cn
# GOLD_API_APPKEY=your_goldapi_key

# ── 飞书配置（可选） ──
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
